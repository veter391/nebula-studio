{
  "name": "nebula-studio",
  "version": "2.9.0",
  "description": "Production-grade browser-based beat maker and step sequencer — pure Web Audio API, zero dependencies, zero build step.",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "dev": "python3 -m http.server 8080",
    "start": "python3 -m http.server 8080",
    "serve": "python3 -m http.server 8080",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,css}\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\" \"*.md\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy"
  },
  "keywords": [
    "web-audio",
    "daw",
    "beat-maker",
    "step-sequencer",
    "music",
    "synthesizer",
    "drum-machine",
    "audio",
    "vanilla-js",
    "no-build"
  ],
  "author": "Nebula Studio contributors",
  "license": "MIT",
  "engines": {
    "node": ">=14"
  },
  "dependencies": {},
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "vitest": "^4.1.9"
  },
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 88",
    "Safari >= 14.5",
    "Edge >= 90"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/veter391/nebula-studio.git"
  },
  "bugs": {
    "url": "https://github.com/veter391/nebula-studio/issues"
  },
  "homepage": "https://github.com/veter391/nebula-studio#readme"
}